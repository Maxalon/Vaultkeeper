# ┌───────────────────────────────────────────────────────────────────────┐
# │ Vaultkeeper — staging environment template                            │
# │                                                                       │
# │ Copy to .env.staging on the deploy host. Same shape as .env.prod but  │
# │ differs on: host ports, DB / Redis / MinIO credentials, APP_URL, and  │
# │ the image tag (staging branch instead of main).                       │
# │                                                                       │
# │ Staging runs side-by-side with prod on the same host, isolated by    │
# │ compose project name:                                                 │
# │                                                                       │
# │   docker compose -f docker-compose.prod.yml                           │
# │       --env-file .env.staging                                         │
# │       -p vaultkeeper_staging up -d                                    │
# │                                                                       │
# │ Each project gets its own containers / volumes / network. Staging    │
# │ and prod share zero runtime state.                                    │
# └───────────────────────────────────────────────────────────────────────┘

# ─── Host port bindings ────────────────────────────────────────────────────
# Alternate ports so prod keeps 80/443. Staging is typically hit via a
# separate Tailscale hostname, so a second nginx can coexist fine.
HTTP_PORT=8080
HTTPS_PORT=8443
MINIO_CONSOLE_PORT=9002

# ─── Application ───────────────────────────────────────────────────────────
APP_ENV=staging
APP_DEBUG=false
APP_URL=https://staging-CHANGEME.CHANGEME.ts.net

APP_KEY=CHANGEME
JWT_SECRET=CHANGEME

LOG_CHANNEL=stderr
LOG_LEVEL=info

HORIZON_ALLOWED_EMAILS=you@example.com

# ─── Database ──────────────────────────────────────────────────────────────
# MUST differ from .env.prod so an accidental misconfiguration can't
# point staging at prod data (or vice versa).
DB_DATABASE=vaultkeeper_staging
DB_USERNAME=vaultkeeper_staging
DB_PASSWORD=CHANGEME
MYSQL_ROOT_PASSWORD=CHANGEME

# ─── Object storage ────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
ASSETS_BUCKET=vaultkeeper-staging-assets

# ─── Images ────────────────────────────────────────────────────────────────
# Staging follows the `staging` branch. CI builds + pushes on every
# push to that branch; the deployer pulls the tag. For a pinned deploy
# swap `:staging` for `:<sha>`.
API_IMAGE=ghcr.io/CHANGEME/vaultkeeper-api:staging
NGINX_IMAGE=ghcr.io/CHANGEME/vaultkeeper-nginx:staging
