# ┌─────────────────────────────────────────────────────────────────────────────────────┐
# │ Vaultkeeper — staging environment template                            │
# │                                                                       │
# │ Copy to .env.staging on the deploy host. Same shape as .env.prod but  │
# │ differs on: hostnames, DB / MinIO credentials, image tag.             │
# │                                                                       │
# │ Staging runs side-by-side with prod on the same host, isolated by    │
# │ compose project name AND by domain (vault-staging.* vs vault.*).      │
# │                                                                       │
# │   docker compose -f docker-compose.prod.yml                           │
# │       --env-file .env.staging                                         │
# │       -p vaultkeeper_staging up -d                                    │
# └─────────────────────────────────────────────────────────────────────────────────────┘

# ─── Application ────────────────────────────────────────────────────────────────
APP_ENV=staging
APP_DEBUG=false
APP_URL=https://vault-staging.kontrollzentrale.de

# Distinct from prod's SESSION_DOMAIN so a staging Horizon session can
# never let you into prod Adminer (and vice versa).
SESSION_DOMAIN=.vault-staging.kontrollzentrale.de
SESSION_SECURE_COOKIE=true

ASSETS_PUBLIC_URL=https://assets.vault-staging.kontrollzentrale.de

APP_KEY=CHANGEME
JWT_SECRET=CHANGEME

LOG_CHANNEL=stderr
LOG_LEVEL=info

HORIZON_ALLOWED_EMAILS=you@example.com

# Horizon dashboard mount — see .env.prod.example for the full rationale.
# Short version: HORIZON_PATH must be a non-empty prefix without a
# leading slash. Empty / `/` causes the package's SPA catch-all to
# shadow /login and /setup; a leading slash makes Horizon's frontend
# build broken protocol-relative URLs (`'/' + '/dashboard'` =
# `//dashboard`, which resolves to host `dashboard`). Keep at
# `dashboard`.
HORIZON_DOMAIN=horizon.vault-staging.kontrollzentrale.de
HORIZON_PATH=dashboard

# ─── Mail (Google Workspace SMTP relay) ─────────────────────────────────────────
# Same relay as prod — see .env.prod.example for the one-time Workspace
# setup (add the domain, turn on DKIM/SPF/DMARC, enable the SMTP relay).
# Staging sends real mail so reset/verify flows can be tested end to end.
# Reset emails are queued, so MAIL_* must reach the `worker` too (handled
# in docker-compose.prod.yml).
#
# MAIL_USERNAME / MAIL_PASSWORD: a Workspace user + app password. Reuse
# prod's, or use a separate staging user if you want leak isolation.
# MAIL_FROM_ADDRESS must be on a domain registered in your Workspace; the
# "(staging)" name keeps test mail visually distinct from prod.
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGEME
MAIL_PASSWORD=CHANGEME
MAIL_FROM_ADDRESS=no-reply@vaultkeeper.cards
MAIL_FROM_NAME="Vaultkeeper (staging)"

# ─── Database ─────────────────────────────────────────────────────────────────────────
# MUST differ from .env.prod so an accidental misconfiguration can't
# point staging at prod data (or vice versa).
DB_DATABASE=vaultkeeper_staging
DB_USERNAME=vaultkeeper_staging
DB_PASSWORD=CHANGEME
MYSQL_ROOT_PASSWORD=CHANGEME

# ─── Object storage ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
ASSETS_BUCKET=vaultkeeper-staging-assets

# ─── Images ──────────────────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/CHANGEME/vaultkeeper-api:staging
SPA_IMAGE=ghcr.io/CHANGEME/vaultkeeper-spa:staging
