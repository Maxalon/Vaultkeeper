APP_NAME=Vaultkeeper
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
# Replace the CHANGEME placeholders before running `docker compose up`.
# The dev MySQL container binds 3306 to the host, so leaving defaults
# here means any process on your machine (or on a reachable network
# like Tailscale) could connect with the checked-in values.
DB_DATABASE=vaultkeeper
DB_USERNAME=vaultkeeper
DB_PASSWORD=CHANGEME

MYSQL_ROOT_PASSWORD=CHANGEME

# Populated by `docker compose exec api php artisan jwt:secret`.
JWT_SECRET=

VITE_API_BASE_URL=/api
