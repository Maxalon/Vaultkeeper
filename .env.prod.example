# ┌─────────────────────────────────────────────────────────────────────────────────────┐
# │ Vaultkeeper — production environment template                         │
# │                                                                       │
# │ Copy this file to .env.prod on the deploy host (NEVER commit the      │
# │ filled-in copy) and replace every placeholder marked CHANGEME before  │
# │ starting the stack.                                                   │
# │                                                                       │
# │ Used by: docker compose -f docker-compose.prod.yml                    │
# │              --env-file .env.prod                                     │
# │              -p vaultkeeper_prod up -d                                │
# └─────────────────────────────────────────────────────────────────────────────────────┘
#
# No HTTP/HTTPS port bindings here — Caddy (kontrollzentrale repo) owns
# :80/:443 on the host and reaches every backend by container name on
# the shared `edge` Docker network.

# ─── Application ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
# Public site. The legacy host vault.kontrollzentrale.de 301-redirects
# here at the Caddy edge. APP_URL also drives CORS allowed_origins
# (config/cors.php) and the base of password-reset links.
APP_URL=https://vaultkeeper.cards

# Ops session cookie. Scoped to the *.vault.kontrollzentrale.de ops
# subdomains (horizon.*, adminer.*) where the same Horizon login gates
# both. NOT changed to vaultkeeper.cards: the public app authenticates
# with Bearer JWTs (config/cors.php supports_credentials=false), so it
# doesn't rely on this cookie, while Horizon/Adminer still live on
# kontrollzentrale.de. Prod/staging stay isolated by domain.
SESSION_DOMAIN=.vault.kontrollzentrale.de
SESSION_SECURE_COOKIE=true

# Static asset URL (set symbols, mana symbols, card backs). Caddy
# rewrites this host to the MinIO bucket root so /symbols/W.svg →
# minio:9000/vaultkeeper-assets/symbols/W.svg. Baked into the SPA at
# build time (VITE_ASSETS_URL in deploy.yml) — keep the two in lockstep.
ASSETS_PUBLIC_URL=https://assets.vaultkeeper.cards

# Laravel encryption key — generate once with:
#   docker run --rm vaultkeeper-api:prod php artisan key:generate --show
# then paste the `base64:...` string here. NEVER reuse the dev key.
APP_KEY=CHANGEME

# JWT signing secret for tymon/jwt-auth — generate once with:
#   docker run --rm vaultkeeper-api:prod php artisan jwt:secret --show
# then paste the raw string here.
JWT_SECRET=CHANGEME

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Comma-separated email addresses allowed to hit the Horizon dashboard
# in prod. The users still have to authenticate normally; this is a
# second gate on top of Laravel auth. Leave blank to deny everyone.
HORIZON_ALLOWED_EMAILS=you@example.com

# Operator address that receives the one-time /setup token on first
# deploy (or after `horizon:reset-credentials`). The token used to be
# written to the application log, where any reader could grab it
# before the legitimate operator did. If unset, the token is only
# retrievable via `docker compose exec api php artisan horizon:setup-token`.
HORIZON_SETUP_EMAIL=you@example.com

# Horizon dashboard mount.
#
# HORIZON_DOMAIN scopes Horizon's routes to a dedicated subdomain so
# its package SPA catch-all (Route::get('/{view?}')) doesn't claim
# arbitrary paths on the api domain (vault.*).
#
# HORIZON_PATH must be a NON-EMPTY prefix WITHOUT a leading slash.
#   - Empty / `/` is forbidden because the catch-all would shadow
#     /login and /setup on the subdomain root, causing a redirect loop.
#   - A leading slash is forbidden because Horizon's frontend JS
#     constructs its API URLs as `'/' + config.path + '/api/...'`.
#     If the configured path is `/dashboard`, that interpolation
#     produces `//dashboard/api/...`, which the browser interprets
#     as a protocol-relative URL pointing at host `dashboard` and
#     the request fails with ERR_NAME_NOT_RESOLVED.
#
# Use `dashboard` here. Laravel's route prefix system handles the
# slash on the server side, so the dashboard URL is still
# https://horizon.vault.kontrollzentrale.de/dashboard.
HORIZON_DOMAIN=horizon.vault.kontrollzentrale.de
HORIZON_PATH=dashboard

# ─── Mail (Google Workspace SMTP relay) ─────────────────────────────────────────
# Outgoing mail (password resets, etc.) goes through the Google Workspace
# SMTP relay. Reset emails are queued — the `worker` service is what
# actually dispatches them, so MAIL_* must be present there too (handled
# in docker-compose.prod.yml).
#
# Workspace setup (one-time, in the Admin console):
#   1. Add vaultkeeper.cards to the account (primary/secondary/alias
#      domain) and verify it.
#   2. Turn on DKIM for vaultkeeper.cards (Apps → Google Workspace →
#      Gmail → Authenticate email) and publish the printed TXT record.
#   3. Publish SPF (`v=spf1 include:_spf.google.com ~all`) and a DMARC
#      record on the zone.
#   4. Apps → Gmail → Routing → SMTP relay service: enable it, allow
#      "Only registered Apps users", require SMTP authentication + TLS.
#
# MAIL_USERNAME / MAIL_PASSWORD: a Workspace user on the domain plus an
# app password for it (the user account must have 2-step verification
# on; generate the app password at https://myaccount.google.com/apppasswords).
# Port 587 negotiates STARTTLS (leave MAIL_SCHEME unset for that).
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGEME
MAIL_PASSWORD=CHANGEME
MAIL_FROM_ADDRESS=no-reply@vaultkeeper.cards
MAIL_FROM_NAME=Vaultkeeper

# ─── Database (MySQL 8.4) ────────────────────────────────────────────────────────
DB_DATABASE=vaultkeeper
DB_USERNAME=vaultkeeper
DB_PASSWORD=CHANGEME
MYSQL_ROOT_PASSWORD=CHANGEME

# ─── Object storage (MinIO) ───────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
ASSETS_BUCKET=vaultkeeper-assets

# ─── Images ──────────────────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/CHANGEME/vaultkeeper-api:main
SPA_IMAGE=ghcr.io/CHANGEME/vaultkeeper-spa:main
