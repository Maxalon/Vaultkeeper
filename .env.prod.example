# ┌───────────────────────────────────────────────────────────────────────┐
# │ Vaultkeeper — production environment template                         │
# │                                                                       │
# │ Copy this file to .env.prod on the deploy host (NEVER commit the      │
# │ filled-in copy) and replace every placeholder marked CHANGEME before  │
# │ starting the stack.                                                   │
# │                                                                       │
# │ Used by: docker compose -f docker-compose.prod.yml                    │
# │              --env-file .env.prod                                     │
# │              -p vaultkeeper_prod up -d                                │
# └───────────────────────────────────────────────────────────────────────┘

# ─── Host port bindings ────────────────────────────────────────────────────
# nginx edge. 80/443 are the defaults; change only if something else on
# the host already owns them.
HTTP_PORT=80
HTTPS_PORT=443

# MinIO admin console. Bound to 127.0.0.1 in the compose file, so it's
# only reachable over Tailscale via the host's tailnet IP on this port.
MINIO_CONSOLE_PORT=9001

# ─── Application ───────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=https://CHANGEME.CHANGEME.ts.net

# Laravel encryption key — generate once with:
#   docker run --rm vaultkeeper-api:prod php artisan key:generate --show
# then paste the `base64:...` string here. NEVER reuse the dev key.
APP_KEY=CHANGEME

# JWT signing secret for tymon/jwt-auth — generate once with:
#   docker run --rm vaultkeeper-api:prod php artisan jwt:secret --show
# then paste the raw string here.
JWT_SECRET=CHANGEME

# Log to stderr so `docker logs` captures everything. Set LOG_LEVEL to
# `warning` once the deploy is stable; during first boot you can drop
# to `info` or `debug` to chase down issues.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Comma-separated email addresses allowed to hit /horizon in prod. The
# users still have to authenticate normally; this is a second gate on
# top of Laravel auth. Leave blank to deny everyone.
HORIZON_ALLOWED_EMAILS=you@example.com

# ─── Database (MySQL 8.4) ──────────────────────────────────────────────────
DB_DATABASE=vaultkeeper
DB_USERNAME=vaultkeeper
DB_PASSWORD=CHANGEME
MYSQL_ROOT_PASSWORD=CHANGEME

# ─── Object storage (MinIO) ────────────────────────────────────────────────
# Credentials for the bundled MinIO container. MinIO will bootstrap with
# these on first run and create the bucket via the minio-init one-shot.
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
ASSETS_BUCKET=vaultkeeper-assets

# ─── Images ────────────────────────────────────────────────────────────────
# The CI pipeline pushes to ghcr.io; the deployer pulls by tag. Both
# ${IMAGE_TAG} in the registry path is the git ref or SHA that CI
# pushed — `main` for prod, `staging` for staging, or a specific SHA
# for a pinned deploy.
API_IMAGE=ghcr.io/CHANGEME/vaultkeeper-api:main
NGINX_IMAGE=ghcr.io/CHANGEME/vaultkeeper-nginx:main
